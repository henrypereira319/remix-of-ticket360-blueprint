:60,isObserveUrlChangesInitialized:!1,sendRecoveryEvent:function(context){if(null===Pushnews.cartRecovery.lastRecoveryEventDate||Date.now()-Pushnews.cartRecovery.lastRecoveryEventDate>Pushnews.cartRecovery.maxSecondsPerRecoveryEvent*1000){Pushnews.cartRecovery.lastRecoveryEventDate=Date.now();IlabsPush.push(["ecommerce.itemAddedToCart",...(context?[{context}]:[])])}else{console.log("IlabsPush:ecommerce.itemAddedToCart was prevented: too soon to be sent again.")}},custom:{monitorDataLayer:function(){window.dataLayer=window.dataLayer||[];const originalPush=window.dataLayer.push;window.dataLayer.push=function(){const result=originalPush.apply(this,arguments);if(arguments?.[0]?.event==='add_to_cart'){let item=arguments?.[0]?.ecommerce?.items[0];let context={name:item?.item_name,price:item?.price,url:window.location.href,};Pushnews.cartRecovery.sendRecoveryEvent(context)}
Pushnews.cartRecovery.custom.detectAndTrackConversion(arguments?.[0]);return result};if(window.dataLayer&&Array.isArray(window.dataLayer)){window.dataLayer.forEach(obj=>{Pushnews.cartRecovery.custom.detectAndTrackConversion(obj)})}},detectAndTrackConversion:function(dataLayerObject){if(dataLayerObject?.event==='purchase'){window.IlabsPush.push(["trackConversion",{context:{amount:dataLayerObject?.ecommerce?.value,currency:dataLayerObject?.ecommerce?.currency,totalProducts:dataLayerObject?.ecommerce?.items?.reduce((acc,product)=>acc+product.quantity,0)??0,url:window.location.href,}}])}},observeUrlChanges:function(){var previousUrl=location.href;var observer=new MutationObserver(function(mutations){if(location.href!==previousUrl&&''!==previousUrl){previousUrl=location.href;setTimeout(function(){Pushnews.cartRecovery.custom.init()},1500)}});observer.observe(document,{subtree:!0,childList:!0})},init:function(){Pushnews.cartRecovery.custom.monitorDataLayer();if(!Pushnews.cartRecovery.isObserveUrlChangesInitialized){Pushnews.cartRecovery.custom.observeUrlChanges();Pushnews.cartRecovery.isObserveUrlChangesInitialized=!0}}},init:function(){Pushnews.cartRecovery.custom.init()}}
