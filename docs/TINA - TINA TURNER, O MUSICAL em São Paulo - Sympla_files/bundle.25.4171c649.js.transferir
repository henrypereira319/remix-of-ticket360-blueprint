tems .items {\n        display: flex;\n        flex-wrap: wrap;\n        margin-left: -10px;\n        margin-top: -10px;\n      }\n      .list-items .items.sectors {\n        background-color: var(--background-inverse-color, #ffffff);\n        border-radius: 4px;\n      }\n      .list-items .items .item {\n        width: calc(50% - 10px);\n        flex: 0 0 1;\n        margin-left: 10px;\n        margin-top: 10px;\n      }\n      .list-items .items .item .flex-item {\n        display: flex;\n        flex-direction: column;\n        width: 100%;\n      }\n      .list-items .items .item .flex-item span {\n        margin: 0;\n        height: 50%;\n        width: 100%;\n      }\n      .list-items .items .item .flex-item .text {\n        margin-top: 5px;\n        color: var(--text-medium-color, #7f7f7f);\n        font-weight: normal;\n      }\n      .list-items .items .item.selectable:not([sold-out]) {\n        box-shadow: 0 2px 3px 0 rgba(0, 0, 0, 0.3);\n      }\n      .list-items[single-column] .items .item.selectable {\n        box-shadow: none;\n      }\n      .list-items .items .item.selectable:not([sold-out]):hover {\n        box-shadow:0 2px 9px rgba(0,0,0,0.3);\n        cursor: pointer;\n      }\n      .list-items .items .item.selectable[sold-out] {\n        cursor: auto;\n        box-shadow: none;\n      }\n      .list-items .items .item.selectable[sold-out] .flex-item .text {\n        color: var(--text-light-color);\n      }\n      .sector-header {\n        position: relative;\n        height: 64px;\n      }\n      .sector-header .back {\n        cursor: pointer;\n        position: absolute;\n        top: 0;\n        left: 0;\n        color: var(--text-medium-color, #7f7f7f);\n        font-size: 14px;\n        height: 100%;\n        display: flex;\n        align-items: center;\n        padding-right: 17px;\n      }\n      .sector-header .back:hover {\n        background-color: var(--highlight-color, #5369e5);\n        color: var(--background-inverse-color, #fff