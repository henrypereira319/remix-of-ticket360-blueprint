        font-size: 24px;\n        font-weight: bold;\n        font-style: normal;\n        font-stretch: normal;\n        line-height: normal;\n        color: var(--text-color, #000000);\n      }\n      .offers .dates {\n        position: relative;\n        background-color: var(--background-inverse-color, #ffffff);\n        display: flex;\n        border-radius: 8px;\n        height: 103px;\n        margin-bottom: 20px;\n      }\n      .offers-nav {\n        width: 32px;\n        position: relative;\n        cursor: pointer;\n        display: flex;\n        align-items: center;\n        background-color: var(--neutral-light-pale);\n      }\n\n      .offers-nav:not([more-dates]) {\n        cursor: initial;\n      }\n\n      .offers-nav:not([more-dates]) .offers-nav__icon {\n        fill: var(--text-light-color, #a6a6a6);\n      }\n\n      .offers-nav:hover[more-dates] {\n        background-color: var(--highlight-color, #5369e5);\n      }\n\n      .offers-nav:hover[more-dates] .offers-nav__icon {\n        fill: var(--neutral-light-pale);\n      }\n\n      .offers .nav-container[nav-disabled] .dates {\n        border-radius: 8px;\n      }\n      .nav-container[nav-disabled] .offers-nav {\n        display: none;\n      }\n\n      .offers-nav--left {\n        border-radius: var(--radius-micro) 0 0 var(--radius-micro);\n      }\n\n      .offers-nav--right {\n        border-radius: 0 var(--radius-micro) var(--radius-micro) 0;\n      }\n\n      .offers-nav__icon {\n        width: var(--icon-medium);\n        height: var(--icon-medium);\n        fill: var(--neutral-dark-pure);\n      }\n\n      unknown-carousel {\n        height: 118px;\n      }\n      .offers .dates unknown-carousel .box-wrapper {\n        width: auto;\n        display: flex;\n        flex-direction: column;\n        align-items: flex-start;\n        background-color: var(--background-inverse-color, #ffffff);\n        cursor: pointer;\n        box-sizing: border-box;\n        border-right: 1px solid var(--background-color, #f7f7fa);\n      }\n      .offers\n        .nav-container[nav-disabled]\n        .dates\n        unknown-carousel\n        .box-wrapper.first {\n        border-radius: 4px 0 0 4px;\n      }\n      .offers .dates unknown-carousel .box-wrapper.last {\n        border-radius: 0 4px 4px 0;\n      }\n      .offers .dates unknown-carousel .box-wrapper[selected],\n      .offers .dates unknown-carousel .box-wrapper:hover {\n        background-color: var(--highlight-color, #5369e5);\n        color: var(--background-inverse-color, #ffffff);\n      }\n      .offers .dates unknown-carousel .box-wrapper[selected] {\n        pointer-events: none;\n      }\n      .offers .dates unknown-carousel .box-wrapper[sold-out] {\n        pointer-events: none;\n      }\n      .offers .dates unknown-carousel .box-wrapper .box {\n        width: 122.25px;\n        position: relative;\n        height: 103px;\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        padding: 0 1px;\n      }\n      .offers .dates unknown-carousel .box-wrapper[selected]::before {\n        margin-left: 40px;\n        content: \'\';\n        position: absolute;\n        top: 100%;\n        border-left: 20px solid transparent;\n        border-right: 20px solid transparent;\n        border-top: 15px solid var(--highlight-color, #5369e5);\n      }\n      .offers .dates unknown-carousel .box-wrapper .box .date {\n        width: 100%;\n        font-style: normal;\n        font-stretch: normal;\n        line-height: normal;\n        letter-spacing: 0.2px;\n      }\n      .offers .dates unknown-carousel .box-wrapper .box .date .day-week {\n        font-size: 14px;\n      }\n      .offers\n        .dates\n        unknown-carousel\n        .box-wrapper[sold-out]\n        .box\n        .date\n        .day-week {\n        color: var(--text-light-color);\n      }\n      .offers .dates unknown-carousel .box-wrapper .box .date .day-month {\n        font-size: 24px;\n        font-weight: bold;\n        letter-spacing: 0.3px;\n      }\n      .offers .dates unknown-carousel .box-wrapper .box .date .time {\n        font-size: 18px;\n        font-weight: bold;\n      }\n      .offers\n        .dates\n        unknown-carousel\n        .box-wrapper[sold-out]\n        .box\n        .date\n        .day-month,\n      .offers .dates unknown-carousel .box-wrapper[sold-out] .box .date .time {\n        color: var(--text-light-color, #a6a6a6);\n      }\n\n      .box-wrapper[sold-out][selected] .day-week,\n      .box-wrapper[sold-out][selected] .day-month,\n      .box-wrapper[sold-out][selected] .time {\n        color: var(--background-inverse-color, #ffffff) !important;\n      }\n\n      .cross-sale-header {\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        height: 64px;\n        padding-top: 30px;\n      }\n\n      .cross-sale-header .title-content {\n        display: flex;\n        width: 100%;\n        flex-direction: column;\n        padding-right: 30px;\n      }\n\n      .cross-sale-header h2,\n      .cross-sale-header p {\n        margin: 0;\n      }\n\n      .cross-sale-header .back-button {\n        position: relative;\n        height: 64px;\n        padding-left: 30px;\n        margin-right: 30px;\n      }\n\n      .cross-sale-header .back-button .back {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        cursor: pointer;\n        position: absolute;\n        top: 0;\n        left: 0;\n        font-size: 14px;\n        height: 100%;\n        width: 100%;\n      }\n\n      .cross-sale-header .back-button .back:hover {\n        background-color: var(--highlight-color, #5369e5);\n        border-radius: 8px;\n        padding: 0;\n        width: 100%;\n      }\n\n      .back:hover .back__icon {\n        fill: var(--neutral-light-pale);\n      }\n\n      .cross-sale-header .skip-button {\n        width: auto;\n      }\n\n      svg {\n        position: absolute;\n        top: 0;\n        left: 0;\n      }\n      svg rect {\n        fill: var(--background-inverse-color, #fff);\n      }\n      .list-items[single-column] {\n        width: 439px;\n      }\n      .list-items[single-column] .items {\n        display: block;\n        margin: 0;\n        max-height: 550px;\n        overflow-y: auto;\n        border-radius: 0;\n      }\n      .list-items[single-column] .items .item:first-child {\n        border-top: 0;\n      }\n      .list-items[single-column] .items .item {\n        width: 100%;\n        border-top: solid 2px var(--background-color, #f7f7fa);\n      }\n      .list-items[single-column] .items:first-child {\n        border-radius: 8px;\n      }\n\n      .list-items .items .item.selectable {\n        display: flex;\n      }\n      .list-items[single-column] .items .item.selectable[hovered],\n      .list-items[single-column] .items .item.selectable:hover {\n        box-shadow: none;\n        background-color: var(--highlight-color);\n      }\n      .list-items[single-column] .items .item.selectable[hovered] .title,\n      .list-items[single-column] .items .item.selectable:hover .title {\n        color: var(--background-inverse-color, #ffffff) !important;\n      }\n      .list-items[single-column]\n        .items\n        .item.selectable[hovered]\n        .installments-label,\n      .list-items[single-column]\n        .items\n        .item.selectable:hover\n        .installments-label {\n        color: var(--background-inverse-color, #ffffff);\n      }\n      .list-items[single-column]\n        .items\n        .item.event-offers[hovered][sold-out]\n        > .soldout-label {\n        color: var(--background-inverse-color, #ffffff);\n      }\n      .list-items[single-column] .items .item.card {\n        align-items: center;\n        display: flex;\n        margin: 0;\n        border-radius: 0;\n      }\n      .list-items .items .item.card {\n        align-items: center;\n        display: flex;\n        border-radius: 0;\n      }\n\n      .splitter {\n        display: flex;\n      }\n\n      #tabs-event-types {\n        display: flex;\n        justify-content: space-around;\n        align-items: center;\n        background-color: var(--background-color, #f7f7fa);\n        padding: 20px 0;\n        color: var(--background-inverse-color, #ffffff);\n        height: 103px;\n        transition: 0.5s linear all;\n      }\n\n      #tabs-event-types svg {\n        position: inherit;\n      }\n\n      .tab-event-item {\n        position: relative;\n        background-color: var(--background-inverse-color, #ffffff);\n        color: var(--text-color, #000000);\n        width: 50%;\n        cursor: pointer;\n        height: 100%;\n      }\n\n      .tab-event-item:first-child {\n        border-right: 2px solid var(--background-color, #f7f7fa);\n      }\n\n      .tab-event-item[active] {\n        background: var(--highlight-color, #5369e5);\n        color: var(--background-inverse-color, #ffffff);\n      }\n\n      .tab-event-item[active]::before {\n        margin-left: calc(50% - 20px);\n        content: \'\';\n        position: absolute;\n        top: 100%;\n        border-left: 20px solid transparent;\n        border-right: 20px solid transparent;\n        border-top: 15px solid var(--highlight-color, #5369e5);\n      }\n\n      .tab-event-item[active] .icon-event-tab {\n        color: var(--background-inverse-color, #ffffff);\n      }\n\n      .tab-dates {\n        border-top-left-radius: 5px;\n        border-bottom-left-radius: 5px;\n      }\n\n      .tab-bundles {\n        border-top-right-radius: 5px;\n        border-bottom-right-radius: 5px;\n      }\n\n      .tab-text-content {\n        margin-right: 26px;\n        vertical-align: middle;\n        padding-left: 25px;\n        line-height: 0.5;\n        flex-grow: 1;\n        font-size: 14px;\n      }\n\n      .tab-icon {\n        margin-right: 0;\n        padding-left: 0;\n        margin-left: 25px;\n        display: var(--icons-status, inline-block);\n      }\n\n      .tab-event-item[active] .tab-event__icon {\n        fill: var(--neutral-light-pale);\n      }\n\n      .tab-event__icon {\n        fill: var(--highlight-color, #5369e5);\n        width: var(--icon-large);\n        height: var(--icon-large);\n      }\n\n      .box-tab-content {\n        width: 100%;\n        height: 100%;\n        display: flex;\n        justify-content: space-around;\n        align-items: center;\n        padding-left: var(--spacing-small-6);\n      }\n\n      .icon-event-tab {\n        color: var(--highlight-color, #5369e5);\n        width: 36px;\n        height: 33px;\n      }\n\n      schematic-map {\n        --container-mixin: {\n          border-radius: 8px;\n        }\n      }\n      .sector-loading {\n        position: relative;\n        height: 610px;\n        width: 100%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n      }\n\n      .installments-label {\n        padding-top: 3px;\n        font-size: 11px;\n        font-weight: bold;\n        color: var(--positive-color);\n      }\n      .soldout-label {\n        font-size: 14px;\n        color: var(--text-medium-color);\n        padding-right: 24px;\n      }\n\n      .d-flex {\n        display: flex;\n      }\n\n      .flex-column {\n        flex-direction: column;\n      }\n\n      .timezone-info {\n        color: #979797;\n        font-size: 16px;\n        margin-bottom: 20px;\n      }\n      [hidden] {\n        display: none !important;\n      }\n    </style>\n\n    <feature-flags id="featureFlags" config="[[config]]"></feature-flags>\n\n    <app-route route="[[route]]" pattern="/b" active="{{_bundlesActive}}">\n    </app-route>\n\n    <app-route\n      route="[[route]]"\n      pattern="/d/:dateId"\n      data="{{_dRouteData}}"\n      tail="{{_sRoute}}"\n    >\n    </app-route>\n\n    <app-route\n      id="sectorRoute"\n      route="[[_sRoute]]"\n      pattern="/s/:sectorId"\n      data="{{_sRouteData}}"\n    >\n    </app-route>\n\n    <div\n      class="cross-sale-header"\n      hidden$="[[!_showCrossSaleTitle(isCrossSale)]]"\n    >\n      \x3c!-- TODO: Melhorar esse html, aqui poderia ser um icon-button --\x3e\n      <div class="back-button card sta-cs-back-button">\n        <div class="back" on-tap="_returnToMainEvent">\n          <sb-icon class="back__icon" icon="arrow-left"></sb-icon>\n        </div>\n      </div>\n      <div class="title-content">\n        <span>\n          <h2 class="sta-cs-book-title">[[i18n.cross_selling.header.title]]</h2>\n        </span>\n        <span>\n          <p class="sta-cs-book-description">\n            [[i18n.cross_selling.header.description]]\n          </p>\n        </span>\n      </div>\n      <div class="skip-button">\n        <app-button\n          class="sta-cs-skip-button"\n          hidden$="[[_shouldHideSkipCrossSaleButton(isCrossSale, shouldUseOldSkipCrossSaleExperience)]]"\n          type="highlight"\n          on-tap="_skipCrossSale"\n        >\n          Pular Etapa\n        </app-button>\n      </div>\n    </div>\n\n    <div\n      id="tabs-event-types"\n      hidden$="[[!_showEventTabs(_event.dates, _bundles)]]"\n    >\n      <div class="tab-event-item tab-dates" active$="[[!_bundlesActive]]">\n        <div class="box-tab-content" on-tap="_changeTabToDates">\n          <sb-icon class="tab-event__icon" icon="calendar"></sb-icon>\n          <div class="tab-text-content">\n            <template is="dom-if" if="[[_isUniqueDate(_event)]]">\n              <h2>[[_getTabInfo(_event)]]</h2>\n              <p>Selecione uma das opções abaixo.</p>\n            </template>\n            <template is="dom-if" if="[[!_isUniqueDate(_event)]]">\n              <h2>Escolha uma data</h2>\n              <p>Selecione um dia que deseja ir ao evento.</p>\n            </template>\n          </div>\n        </div>\n      </div>\n      <div class="tab-event-item tab-bundles" active$="[[_bundlesActive]]">\n        <div\n          class="box-tab-content sta-book-bundle-tab"\n          on-tap="_changeTabToBundles"\n        >\n          <sb-icon class="tab-event__icon" icon="ticket-with-star"></sb-icon>\n          <div class="tab-text-content">\n            <h2>Pacote Promocional</h2>\n            <p>Opções promocionais para este evento.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div\n      class="offers"\n      hidden$="[[!_isRenderComponentType(loading, _bundlesActive, \'dates\')]]"\n    >\n      <div\n        class="nav-container"\n        nav-disabled$="[[!_isNavCompleted(_event.dates.items)]]"\n        hidden$="[[shouldHideEventPeriodDateSelector]]"\n      >\n        <div class="d-flex flex-column">\n          <div\n            class="nav-title"\n            hidden$="[[!_showEventNavTitles(_event.dates, _bundles, isCrossSale)]]"\n          >\n            Selecione uma data\n          </div>\n          <span class="timezone-info">\n            Horários referentes ao local do evento.\n          </span>\n        </div>\n        <nav class="dates">\n          <div\n            class="offers-nav offers-nav--left"\n            on-tap="_navLeft"\n            more-dates$="[[!_isCarouselFirstPage(_currentFirstDate)]]"\n          >\n            <sb-icon class="offers-nav__icon" icon="chevron-left"></sb-icon>\n          </div>\n          <unknown-carousel\n            id="datesCarousel"\n            class="sta-presentation-dates"\n            items="8"\n            controls="false"\n            dots="false"\n            dottext="false"\n            on-onmove="_movedCarousel"\n          >\n            <template\n              is="dom-repeat"\n              items="[[_event.dates.items]]"\n              on-rendered-item-count-changed="_datesRendered"\n            >\n              <div\n                class$="box-wrapper [[_dateClass(index)]]"\n                sold-out$="[[_isDateSoldOut(item)]]"\n                selected$="[[_isDateSelected(_date, item)]]"\n                on-tap="_selectDateTap"\n              >\n                <div class="box">\n                  <div class="date">\n                    <div class="day-week">[[_computeDayWeek(item)]]</div>\n                    <div class="day-month sta-presentation-dates-list">\n                      [[_computeDayMouth(item)]]\n                    </div>\n                    <div class="time" hidden$="[[hideEventTime]]">\n                      [[_computeTime(item)]]\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </template>\n          </unknown-carousel>\n          <div\n            class="offers-nav offers-nav--right"\n            on-tap="_navRight"\n            more-dates$="[[!_isCarouselLastPage(_currentFirstDate)]]"\n          >\n            <sb-icon class="offers-nav__icon" icon="chevron-right"></sb-icon>\n          </div>\n        </nav>\n      </div>\n\n      <template is="dom-if" if="[[_showSectorLabel(_date, _sector, _event)]]">\n        <div class="title">\n          Selecione um [[_getSectorLabel(_event.dates.type)]]\n        </div>\n      </template>\n      <div class="splitter" hidden="[[_sectorListHidden(_date, _sector)]]">\n        <div class="list-items" single-column$="[[_hasSchematicMap(_date)]]">\n          <div id="sectorList" class="items sta-sector-session-list">\n            <template is="dom-repeat" items="[[_date.sectors]]">\n              <div\n                class="item card selectable sta-sector-session-items"\n                on-tap="_selectSector"\n                on-mouseover="_sectorMouseover"\n                on-mouseout="_sectorMouseout"\n                hovered$="[[_isSectorHovered(item.id, _sectorHovered)]]"\n                sold-out$="[[!item.total_available]]"\n              >\n                <div class="flex-item">\n                  <span class="title sta-sector-session-list-text small">\n                    [[item.name]]\n                  </span>\n                  <span class="title small tex