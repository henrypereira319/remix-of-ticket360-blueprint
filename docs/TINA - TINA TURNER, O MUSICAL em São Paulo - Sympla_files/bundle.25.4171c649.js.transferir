ntFinished]]" restamp>\n            <div class="banner-container">\n              <div class="banner-info-container">\n                <h1 class="event-name sta-event-title-text">\n                  <span>[[_event.name]]</span>\n                </h1>\n                <template is="dom-if" if="[[!_eventFinished]]" restamp>\n                  <section class="pre-description">\n                    <div>\n                      <div\n                        class="event-information-container"\n                        hidden$="[[_event.hide_event_date_time]]"\n                      >\n                        <sb-icon\n                          class="description__icon"\n                          icon="calendar"\n                        ></sb-icon>\n                        <p\n                          class="title sta-event-week-date-text"\n                          hidden$="[[_event.hide_event_date_time]]"\n                        >\n                          [[_event.date_summary.period]]\n                        </p>\n                      </div>\n                      <div\n                        class="event-information-container"\n                        hidden$="[[_hasDateSummary(_event.date_summary, _event.hide_event_date_time)]]"\n                      >\n                        <sb-icon\n                          class="description__icon"\n                          icon="clock"\n                        ></sb-icon>\n                        <div>\n                          <p\n                            class="title sta-event-week-date-text"\n                            hidden$="[[!_event.date_summary.week]]"\n                          >\n                            [[_processedSummaryWeek(_event.date_summary.week,\n                            _event.hide_event_time)]]\n                          </p>\n                          <p\n                            class="info info-timezone sta-event-period-date-text"\n                            hidden$="[[_event.hide_event_time]]"\n                          >\n                            Horários referentes ao local do evento.\n                          </p>\n                        </div>\n                      </div>\n\n                      <div class="event-information-container adress">\n                        <sb-icon\n                          class="description__icon"\n                          icon="map-marker"\n                        ></sb-icon>\n                        <div class="address">\n                          <span class="title sta-event-venue-address-text">\n                            [[_event.venue.name]] -\n                            <span class="title sta-event-venue-address-text"\n                              >[[_event.venue.locale.address]],\n                              [[_event.venue.locale.city.name]] -\n                              [[_event.venue.locale.state.name]]\n                            </span>\n                          </span>\n                        </div>\n                      </div>\n\n                      <template is="dom-if" if="[[!_isEventFree]]">\n                        <installments-incentive></installments-incentive>\n                      </template>\n                    </div>\n                  </section>\n                </template>\n              </div>\n              <div class="floated-image image-16-by-9 sta-event-profile-image">\n                <template id="ie-if-wrapper" is="dom-if" if="[[_isIE]]" restamp>\n                  <img\n                    class="picture"\n                    src$="[[_ie11Image]]"\n                    alt$="[[_event.name]]"\n                  />\n                </template>\n                <template is="dom-if" if="[[!_isIE]]" restamp>\n                  <picture class="picture">\n                    <template is="dom-repeat" items="[[_medias]]">\n                      <source srcset$="[[item.url]]" type$="[[item.type]]" />\n                    </template>\n                    <img\n                      class="event-image"\n                      src="/src/images/gray-background.png"\n                      alt$="[[_event.name]]"\n                    />\n                  </picture>\n                  <div class="share-button-container" hidden="[[!_event]]">\n                    <div class="share-button-center">\n                      <share-button on-click="_openShareModal"></share-button>\n                    </div>\n                  </div>\n                </template>\n                <div class="shimmer-animation"></div>\n              </div>\n            </div>\n          </template>\n        </div>\n      </div>\n\n      <section class="event__section" event-finished$="[[_eventFinished]]">\n        <template is="dom-if" if="[[_loading]]" restamp>\n          <div class="summary shimmer-wrapper">\n            <div class="event-name shimmer-animation"></div>\n            <div class="event-information-container shimmer-animation"></div>\n            <div class="container-summary-range shimmer-animation"></div>\n          </div>\n        </template>\n\n        <template is="dom-if" if="[[_eventFinished]]" restamp>\n          <template\n            is="dom-if"\n            if="[[_showBannerTopsort(config.name)]]"\n            restamp\n          >\n            <banner-topsort\n              id-banner="[[_getIdBannerTopsort()]]"\n              config="{{config}}"\n              is-padding\n              page-location="event-page"\n              position="1"\n            ></banner-topsort>\n          </template>\n        </template>\n\n        <div class="summary">\n          <template is="dom-if" if="[[!_eventFinished]]" restamp>\n            <div class="container-summary-range">\n              <div class="range-tickets">\n                <div class="ticket-information">\n                  <div class="ticket-label-container">\n                    <sb-icon class="description__icon" icon="ticket"></sb-icon>\n                    <p\n           